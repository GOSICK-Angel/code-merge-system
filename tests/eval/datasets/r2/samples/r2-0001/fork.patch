+// matchPattern matches a file path against a glob pattern
+// Supports * for single directory level and ** for recursive matching
+func matchPattern(pattern, path string) (bool, error) {
+	// Handle exact match
+	if pattern == path {
+		return true, nil
+	}
+
+	// Convert glob pattern to regex
+	// Escape special regex characters except * and /
+	regexPattern := regexp.QuoteMeta(pattern)
+	
+	// Replace ** with a special placeholder first to avoid confusion with *
+	regexPattern = strings.ReplaceAll(regexPattern, `\*\*`, "§DOUBLESTAR§")
+	
+	// Replace single * with [^/]* (match anything except /)
+	regexPattern = strings.ReplaceAll(regexPattern, `\*`, `[^/]*`)
+	
+	// Replace ** placeholder with .* (match anything including /)
+	regexPattern = strings.ReplaceAll(regexPattern, "§DOUBLESTAR§", `.*`)
+	
+	// Anchor the pattern
+	regexPattern = "^" + regexPattern + "$"
+	
+	matched, err := regexp.MatchString(regexPattern, path)
+	if err != nil {
+		return false, err
+	}
+	
+	return matched, nil
+}
