+// startCleanupOnce starts the session cleanup goroutine only once
+func startCleanupOnce() {
+	cleanupInitLock.Lock()
+	defer cleanupInitLock.Unlock()
+
+	if !cleanupInitialized {
+		cleanupInitialized = true
+		go sessionCleanupLoop()
+	}
+}
+
+// sessionCleanupLoop runs periodically to clean up expired sessions
+func sessionCleanupLoop() {
+	ticker := time.NewTicker(SESSION_CLEANUP_INTERVAL)
+	defer ticker.Stop()
+
+	for range ticker.C {
+		cleanupExpiredSessions()
+	}
+}
+
+// cleanupExpiredSessions removes sessions that have exceeded their TTL
+func cleanupExpiredSessions() {
+	now := time.Now()
+	expiredSessions := make([]string, 0)
+
+	// Collect expired session IDs
+	session_lock.RLock()
+	for id, session := range sessions {
+		// Use LastAccessedAt for TTL calculation to handle inactive sessions
+		if now.Sub(session.LastAccessedAt) > SESSION_DEFAULT_TTL {
+			expiredSessions = append(expiredSessions, id)
+		}
+	}
+	session_lock.RUnlock()
+
+	// Delete expired sessions
+	if len(expiredSessions) > 0 {
+		log.Info("cleaning up %d expired sessions", len(expiredSessions))
+
+		for _, id := range expiredSessions {
+			session_lock.Lock()
+			delete(sessions, id)
+			session_lock.Unlock()
+
+			// Also delete from cache
+			if _, err := cache.Del(sessionKey(id)); err != nil && err != cache.ErrNotFound {
+				log.Error("failed to delete session %s from cache: %s", id, err)
+			}
+		}
+	}
+}
+
+// GetAllSessionsCount returns the number of active sessions (for monitoring)
+func GetAllSessionsCount() int {
+	session_lock.RLock()
+	defer session_lock.RUnlock()
+	return len(sessions)
+}
