+            data = {
+                "model": model_uid,
+                "input": content_text.strip(),
+                "response_format": "mp3",
+                "speed": 1.0,
+                "stream": False,
+            }
+            
+            if prompt_speech:
+                files["prompt_speech"] = ("prompt_speech.wav", prompt_speech, "audio/wav")
+            if prompt_latent:
